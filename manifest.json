{
  "manifest_version": 3,
  "name": "LeetFox",
  "description": "Motivation streak extension with animated fox for LeetCode.",
  "version": "1.0",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "https://leetcode.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/*"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
  {
    "resources": [
      "assets/*.json",
      "assets/*/*.json",
      "assets/*.json",
      "assets/*.js"
    ],
    "matches": ["<all_urls>"]
  }
]
}
